{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": "python .claude/hooks/protect_paths.py" }]
      },
      {
        "matcher": "Bash",
        "hooks": [{ "type": "command", "command": "python .claude/hooks/guard_run.py" }]
      }
    ],
    "Stop": [
      {
        "hooks": [{ "type": "command", "command": "python .claude/hooks/docs_freshness.py" }]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [{ "type": "command", "command": "python .claude/hooks/post_edit.py" }]
      }
    ]
  }
}
